{
    "name": "incluirtecnologia/mova-management-db-migrations",
    "description": "Projeto responsável por conter toda a estrutura para um projeto de migração",
    "type": "project",
    "authors": [
        {
            "name": "Reinan Souza",
            "email": "reinan.souza@mova.vc"
        }
    ],
    "minimum-stability": "stable",
    "repositories": {
        "5": {
            "type": "composer",
            "url": "https://gitlab.mova.vc/api/v4/group/5/-/packages/composer/"
        }
    },
    "require": {
        "robmorgan/phinx": "^0.12"
    },
    "autoload": {
        "psr-4": {
            "Intec\\MovaManagementDbMigrations\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Intec\\MovaManagementDbMigrations\\Test\\": "tests"
        }
    },
    "require-dev": {
        "bamarni/composer-bin-plugin": "^1.8",
        "phpunit/phpunit": "^9.5"
    },
    "config": {
        "process-timeout": 0,
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true,
            "composer/package-versions-deprecated": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "infection/extension-installer": true
        }
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": true,
            "target-directory": "vendor-bin",
            "forward-command": true
        }
    }
}
