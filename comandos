namespace Intec\MovaOperacionalApi\Action\Operator\Price;

use Intec\MovaBase\Controller\HttpController;
use Intec\MovaOperacionalApi\Dto\Operator\Price\OperatorPriceConvertDto;
use Intec\MovaOperacionalApi\Exception\MovaOperacionalApiActionException;
use Intec\MovaPriceOperations\Model\PriceOperations;
use Intec\MovaPriceOperations\Model\ProductOperations;
use Intec\MovaTaskEnqueuer\Service\CloudFnTasksEnqueuer;
use Intec\MovaTaskEnqueuer\Service\Queue\FnQueue;
use Psr\Http\Message\ResponseInterface;
use Psr\Http\Message\ServerRequestInterface;

class OperatorPriceConvert extends HttpController
{
    private CloudFnTasksEnqueuer $cloudFnTasksEnqueuer;
    private ProductOperations $product;
    private PriceOperations $price;

    public function __construct(
        CloudFnTasksEnqueuer $cloudFnTasksEnqueuer,
        ProductOperations $product,
        PriceOperations $price
    ) {
        $this->cloudFnTasksEnqueuer = $cloudFnTasksEnqueuer;
        $this->product = $product;
        $this->price = $price;
    }

    public function __invoke(
        ServerRequestInterface $request,
        ResponseInterface $response,
        int $priceId
    ): ResponseInterface {
        /** @var OperatorPriceConvertDto $priceConverterDto */
        $priceConverterDto = $this->getDto($request);

        $this->checkIfCanConvert($priceId, $priceConverterDto->productId);

        $this->cloudFnTasksEnqueuer->sendTask(
            FnQueue::PRICE_CONVERTION,
            [
                'cotacao_id' => $priceId,
                'produto_id_alvo' => $priceConverterDto->productId,
                'rodar_motor' => false,
                'cancelar_original' => true,
                'automatizar_status' => $priceConverterDto->automateStatus,
            ]
        );

        return $this->toJson($response, 204);
    }

    private function checkIfCanConvert(int $priceId, int $targetProductId): void
    {
        $rawValues = $this->price->getPriceAndComplementaryData($priceId);
        $price = $rawValues['price'];
        $productId = $price['produto_id'];

        if ($productId == $targetProductId) {
            throw new MovaOperacionalApiActionException(
                code: MovaOperacionalApiActionException::CODE_OPERATORPRICECONVERT_ALREADY_THIS_TYPE
            );
        }

        if (!$this->product->areOfTheSamePersonType($productId, $targetProductId)) {
            throw new MovaOperacionalApiActionException(
                code: MovaOperacionalApiActionException::CODE_OPERATORPRICECONVERT_CANNOT_CONVERT
            );
        }
    }
}



