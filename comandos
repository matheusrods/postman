namespace Intec\MovaOperacionalApi\Middleware;

use Intec\MovaOperacionalApi\Exception\MovaOperacionalApiMiddlewareException;
use Intec\MovaOperacionalApi\Model\ButtonOperator;
use Intec\MovaOperacionalApi\Model\Buttons;
use Psr\Http\Message\ResponseInterface;
use Psr\Http\Message\ServerRequestInterface;
use Psr\Http\Server\RequestHandlerInterface;
use Slim\Routing\RouteCollectorProxy;

class OperatorButtonsAuthorizationHandler
{
    public function __construct(private array $buttonsAllowed, private RouteCollectorProxy $app)
    {
    }

    public function __invoke(
        ServerRequestInterface $request,
        RequestHandlerInterface $requestHandler
    ): ResponseInterface {
        $user = $request->getAttribute('auth');

        if (!$this->buttonsAllowed) {
            return $requestHandler->handle($request);
        }

        /** @var ButtonOperator $buttonOperator */
        $buttonOperator = $this->app->getContainer()->get(ButtonOperator::class);

        $buttons = $buttonOperator->getButtonsByOperatorId($user['id']);

        if (!$buttons || !$this->operatorHasAuthorization($buttons)) {
            throw new MovaOperacionalApiMiddlewareException(
                code: MovaOperacionalApiMiddlewareException::CODE_OPERATOR_BUTTON_ACCESS_DENIED
            );
        }

        return $requestHandler->handle($request);
    }

    private function operatorHasAuthorization(array $operatorButtons): bool
    {
        $operatorButtonsName = array_column($operatorButtons, 'nome');

        $operatorHasAuthorization = (bool) array_intersect($this->buttonsAllowed, $operatorButtonsName);

        $endpointHasntAuthorization = (bool) array_intersect($this->buttonsAllowed, [Buttons::B0]);

        return $operatorHasAuthorization || $endpointHasntAuthorization;
    }
}


 public static function getPermissionButtons(string $permissionName): array
    {
        return self::PERMISSIONS[$permissionName]['botoes'];
    }

     public static function getPermissionFullName(string $permissionName): string
    {
        $permission = self::PERMISSIONS[$permissionName];

        return sprintf('%s: %s', $permissionName, $permission['descricao']);
    }

